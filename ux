          <div style={{padding:"18px 28px 26px",display:"grid",gridTemplateColumns:"1fr 1fr",gap:12}} className="g2">
            {EVENTS.map(ev=>(
              <div key={ev.id} style={{background:C.obL,border:`1px solid rgba(201,168,76,.09)`,overflow:"hidden",transition:"border-color .2s"}}
                onMouseEnter={e=>e.currentTarget.style.borderColor="rgba(201,168,76,.3)"} onMouseLeave={e=>e.currentTarget.style.borderColor="rgba(201,168,76,.09)"}>
                <div style={{height:90,background:`linear-gradient(135deg,${C.obL},#111820)`,display:"flex",alignItems:"center",justifyContent:"center",fontSize:34,borderBottom:`1px solid rgba(201,168,76,.07)`}}>{ev.e}</div>
                <div style={{padding:"13px 15px"}}>
                  <div style={{display:"flex",gap:7,marginBottom:7,flexWrap:"wrap",alignItems:"center"}}>
                    <span style={{fontFamily:"monospace",fontSize:9,background:C.tc,color:"white",padding:"2px 7px"}}>{ev.date}</span>
                    {ev.free&&<span style={{fontSize:9,color:C.ok,background:"rgba(46,204,113,.1)",padding:"2px 6px"}}>Free</span>}
                  </div>
                  <div style={{fontFamily:"Georgia,serif",fontSize:16,fontWeight:400,color:C.iv,marginBottom:5}}>{ev.title}</div>
                  <p style={{fontSize:11,color:C.mu,lineHeight:1.65,marginBottom:10}}>{ev.desc}</p>
                  <div style={{display:"flex",justifyContent:"space-between",alignItems:"center"}}>
                    <span style={{fontSize:10,color:C.mu}}>{ev.bkd}/{ev.cap} reserved</span>
                    <BtnG sm onClick={()=>setSelEv(ev)}>{ev.free?"Reserve":"Reserve Spot"}</BtnG>
                  </div>
                  <div style={{background:C.ob,height:2,borderRadius:1,marginTop:8}}><div style={{background:C.gd,height:2,borderRadius:1,width:`${(ev.bkd/ev.cap)*100}%`}}/></div>
                </div>
              </div>
            ))}
          </div>
        </Panel>

        {/* ── CONFERENCING ── */}
        <Panel id="conferencing" active={activePanel} onToggle={togglePanel} icon="🏛" label="Meetings and Conferencing" sub="4 venues · from KES 8,000 · Tash Aqua catering">
          <div className="g2" style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,padding:"18px 28px 26px"}}>
            {ROOMS.map(room=>(
              <div key={room.id} style={{background:C.obL,border:`1px solid rgba(201,168,76,.09)`,padding:16,transition:"border-color .2s",cursor:"pointer"}}
                onClick={()=>setSelRoom(room)}
                onMouseEnter={e=>e.currentTarget.style.borderColor=C.gd} onMouseLeave={e=>e.currentTarget.style.borderColor="rgba(201,168,76,.09)"}>
                <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start",marginBottom:9}}>
                  <span style={{fontFamily:"Georgia,serif",fontSize:17,fontWeight:400,color:C.iv}}>{room.name}</span>
                  <div style={{textAlign:"right",flexShrink:0,marginLeft:8}}>
                    <div style={{fontFamily:"monospace",fontSize:11,color:C.gd}}>{room.rate}</div>
                    <div style={{fontSize:9,color:C.mu}}>per session</div>
                  </div>
                </div>
                <div style={{display:"flex",gap:12,marginBottom:9}}>
                  <span style={{fontSize:11,color:C.mu}}>👥 {room.cap} pax</span>
                  <span style={{fontSize:11,color:C.mu}}>📐 {room.sqft} sqft</span>
                </div>
                <div style={{display:"flex",flexWrap:"wrap",gap:4,marginBottom:11}}>
                  {room.feat.map(f=><span key={f} style={{fontSize:9,background:C.ob,color:C.mu,padding:"2px 8px"}}>{f}</span>)}
                </div>
                <div style={{fontSize:10,color:C.gd,letterSpacing:1.5,textTransform:"uppercase"}}>Enquire →</div>
              </div>
            ))}
          </div>
        </Panel>

        {/* ── INSTAGRAM ── */}
        <Panel id="social" active={activePanel} onToggle={togglePanel} icon="📸" label="Follow Villa Vista" sub={`@${IG1} · @${IG2}`}>
          <div style={{padding:"18px 28px 26px"}}>
            <div style={{display:"flex",gap:10,marginBottom:14,flexWrap:"wrap"}}>
              <a href={`https://www.instagram.com/${IG1}/`} target="_blank" rel="noreferrer" style={{display:"flex",alignItems:"center",gap:8,padding:"9px 16px",background:"linear-gradient(135deg,#833AB4,#FD1D1D,#F77737)",color:"white",textDecoration:"none",fontSize:10,letterSpacing:1.5,textTransform:"uppercase",fontWeight:600}}>📸 @{IG1}</a>
              <a href={`https://www.instagram.com/${IG2}/`} target="_blank" rel="noreferrer" style={{display:"flex",alignItems:"center",gap:8,padding:"9px 16px",background:"rgba(201,168,76,.1)",color:C.gd,textDecoration:"none",fontSize:10,letterSpacing:1.5,textTransform:"uppercase",fontWeight:600,border:`1px solid rgba(201,168,76,.25)`}}>📸 @{IG2}</a>
            </div>
            <div style={{display:"grid",gridTemplateColumns:"repeat(6,1fr)",gap:2}}>
              {IG_POSTS.map(p=>(
                <div key={p.id} onClick={()=>window.open(`https://www.instagram.com/${IG1}/`,"_blank")} style={{aspectRatio:"1/1",background:C.obL,display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",cursor:"pointer",position:"relative",overflow:"hidden",border:`1px solid rgba(201,168,76,.06)`}}
                  onMouseEnter={()=>setIgHov(p.id)} onMouseLeave={()=>setIgHov(null)}>
                  <span style={{fontSize:26}}>{p.e}</span>
                  <span style={{fontSize:8,letterSpacing:1,color:C.mu,marginTop:3,textTransform:"uppercase"}}>#{p.tag}</span>
                  {igHov===p.id&&<div style={{position:"absolute",inset:0,background:"rgba(13,15,20,.9)",display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",padding:8,textAlign:"center"}}>
                    <div style={{fontSize:10,color:C.iv,lineHeight:1.5,marginBottom:4}}>{p.cap}</div>
                    <div style={{fontSize:10,color:C.gd}}>♥ {p.likes}</div>
                  </div>}
                </div>
              ))}
            </div>
          </div>
        </Panel>

        {/* ── MAP ── */}
        <Panel id="map" active={activePanel} onToggle={togglePanel} icon="🗺" label="Floor Map" sub="Ground · First · Second · Third · Basement">
          <div style={{padding:"18px 28px 26px",display:"grid",gridTemplateColumns:"1fr 200px",gap:22,alignItems:"start"}} className="g2">
            <svg viewBox="0 0 300 440" style={{width:"100%",background:C.obL,border:`1px solid rgba(201,168,76,.1)`}}>
              {[88,155,222,290,358].map(y=><line key={y} x1="0" y1={y} x2="300" y2={y} stroke="rgba(201,168,76,.06)" strokeWidth="1" strokeDasharray="4"/>)}
              {[{l:"G",y:54},{l:"1",y:258},{l:"2",y:324}].map(f=><text key={f.l} x="289" y={f.y} fill={C.gdD} fontSize="8" fontFamily="monospace" textAnchor="end">FL {f.l}</text>)}
              {floorZones.map(z=>(
                <g key={z.id} onClick={()=>{setMapZ(z.id===mapZ?null:z.id);if(z.tId){const found=TENANTS.find(t=>t.id===z.tId);if(found)setSelT(found);}}}>
                  <rect x={z.x} y={z.y} width={z.w} height={z.h} rx="2" className={`fz ${mapZ===z.id?"act":""} ${!z.open?"dim":""}`}/>
                  <text x={z.x+z.w/2} y={z.y+z.h/2+4} fill={mapZ===z.id?C.gd:C.mu} fontSize="8" textAnchor="middle" fontFamily="Inter" pointerEvents="none">{z.label}</text>
                </g>
              ))}
            </svg>
            <div>
              {[["Ground","Banking, Dining, Gaming, Electronics"],["First","Fast Food, Retail"],["Second","Wellness, Healthcare, Conferencing"],["Third","Legal and Professional"],["Basement","Parking"]].map(([f,d])=>(
                <div key={f} style={{padding:"8px 11px",marginBottom:5,background:C.obL,borderLeft:`2px solid ${C.gdD}`}}>
                  <div style={{fontSize:9,color:C.gd,marginBottom:1,letterSpacing:1.5,textTransform:"uppercase"}}>{f}</div>
                  <div style={{fontSize:10,color:C.mu,lineHeight:1.5}}>{d}</div>
                </div>
              ))}
              <div style={{marginTop:10,padding:"9px 11px",background:C.obL,border:`1px dashed rgba(201,168,76,.16)`,cursor:"pointer"}} onClick={()=>openPanel("vacancies")}>
                <div style={{fontSize:9,color:C.gd,letterSpacing:1.5,textTransform:"uppercase",marginBottom:4}}>Space Available</div>
                <div style={{fontSize:10,color:C.mu,lineHeight:1.6}}>{VACANCIES.length} units for lease →</div>
              </div>
            </div>
          </div>
        </Panel>

      </div>{/* end panels */}

      {/* ── FOOTER ── */}
      <footer style={{background:C.ob,borderTop:`1px solid rgba(201,168,76,.1)`,padding:"40px 10vw 22px"}}>
        <div className="g2" style={{display:"grid",gridTemplateColumns:"2fr 1fr 1fr 1fr",gap:32,marginBottom:32}}>
          <div>
            <LogoMark h={44}/>
            <p style={{fontSize:12,color:C.mu,lineHeight:1.8,maxWidth:230,marginTop:14}}>Meru's premier lifestyle destination. Maua Road, opposite Kenya Methodist University.</p>
            <div style={{marginTop:12,display:"flex",flexDirection:"column",gap:6}}>
              {[{href:`https://www.instagram.com/${IG1}/`,lbl:`📸 @${IG1}`},{href:`https://www.instagram.com/${IG2}/`,lbl:`📸 @${IG2}`},{href:WA,lbl:"💬 WhatsApp Us"}].map(({href,lbl})=>(
                <a key={lbl} href={href} target="_blank" rel="noreferrer" style={{fontSize:11,color:C.mu,textDecoration:"none",transition:"color .2s"}}
                  onMouseEnter={e=>e.currentTarget.style.color=C.gd} onMouseLeave={e=>e.currentTarget.style.color=C.mu}>{lbl}</a>
              ))}
            </div>
          </div>
          {[["Explore",["Directory","Events","Conferencing","Floor Map"]],["Leasing",["Available Units","Lease Enquiry","Fit-out Guide","Tenant Portal"]],["Contact",["Maua Road, Meru","@villavistameru","Leasing Team","Careers"]]].map(([title,links])=>(
            <div key={title}>
              <div style={{fontSize:9,letterSpacing:3,textTransform:"uppercase",color:C.gd,marginBottom:11}}>{title}</div>
              {links.map(l=><div key={l} style={{fontSize:12,color:C.mu,marginBottom:8,cursor:"pointer",transition:"color .2s"}}
                onMouseEnter={e=>e.target.style.color=C.iv} onMouseLeave={e=>e.target.style.color=C.mu}>{l}</div>)}
            </div>
          ))}
        </div>
        <div style={{height:1,background:`linear-gradient(90deg,${C.gd} 0%,transparent 100%)`,marginBottom:14}}/>
        <div style={{display:"flex",justifyContent:"space-between",flexWrap:"wrap",gap:6}}>
          <span style={{fontSize:10,color:C.mu}}>© 2026 Villa Vista Mall, Meru. All rights reserved.</span>
          <span style={{fontFamily:"monospace",fontSize:9,color:C.gdD}}>Shop · Dine · Experience</span>
        </div>
      </footer>

      {/* ── WHATSAPP ── */}
      <a href={WA} target="_blank" rel="noreferrer" style={{position:"fixed",bottom:22,right:20,zIndex:90,width:50,height:50,background:"#25D366",borderRadius:"50%",display:"flex",alignItems:"center",justifyContent:"center",fontSize:22,boxShadow:"0 4px 16px rgba(37,211,102,.4)",textDecoration:"none",transition:"transform .2s"}}
        onMouseEnter={e=>e.currentTarget.style.transform="scale(1.1)"} onMouseLeave={e=>e.currentTarget.style.transform="scale(1)"}>💬</a>

      {/* ── TRANSACTION WINDOWS ── */}
      {(modal==="register"||modal==="login")&&<AuthModal mode={modal} onClose={()=>setModal(null)} onAuth={auth}/>}
      {selT&&<TenantModal t={selT} onClose={()=>setSelT(null)} onEnquire={enquire} onNotify={notify} user={user}/>}
      {notifyT&&<TxWindow accent={C.gd} bg="#0D1018" icon={notifyT.e} title={`${notifyT.name} — Coming Soon`} sub="We will email you when this tenant opens." onClose={()=>setNotifyT(null)}>
        <div style={{padding:"20px 24px",display:"grid",gap:11}}>
          <Inp label="Your Email" type="email" placeholder="you@example.com"/>
          <BtnG onClick={()=>{notify(notifyT);setNotifyT(null);}} full>Notify Me When Open</BtnG>
        </div>
      </TxWindow>}
      {selEv&&<EventModal ev={selEv} onClose={()=>setSelEv(null)} onEnquire={enquire} user={user}/>}
      {selRoom&&<RoomModal room={selRoom} onClose={()=>setSelRoom(null)} onEnquire={enquire}/>}
      {selVac&&<VacancyModal unit={selVac} onClose={()=>setSelVac(null)} onEOI={submitEOI}/>}
      {showLoyalty&&<LoyaltyModal user={user} onJoin={()=>{auth({name:"New Member",email:"",phone:"",points:500,tier:"Explorer",joined:new Date().toLocaleDateString("en-KE")});}} onClose={()=>setShowLoyalty(false)} onShowDash={()=>{setShowLoyalty(false);}}/>}
      {toast&&<Toast msg={toast} onClose={()=>setToast(null)}/>}
    </div>
  );
}
