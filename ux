    {tabs.map(tb=><button key={tb.id} onClick={()=>onChange(tb.id)} style={{fontSize:10,letterSpacing:1.5,textTransform:"uppercase",padding:"11px 14px",background:"none",border:"none",borderBottom:active===tb.id?`2px solid ${accent}`:"2px solid transparent",color:active===tb.id?accent:C.mu,cursor:"pointer",whiteSpace:"nowrap"}}>{tb.label}</button>)}
