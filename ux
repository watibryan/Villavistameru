}

// ─── TENANT MICROSITE ────────────────────────────────────────
function TenantModal({t,onClose,onEnquire,onNotify,user}) {
  const [tab,setTab]=useState("about");
  const [ms,setMs]=useState(null);
  const open=isOpen(t);
  const tier=getTier(user);
  useEffect(()=>{
    const def=MICROSITE_DEFAULTS[String(t.id)]||defaultMs(t);
    if(window.storage){window.storage.get(`ms-${t.id}`).then(r=>setMs(r?JSON.parse(r.value):def)).catch(()=>setMs(def));}
    else setMs(def);
  },[t.id]);
  if(!ms) return null;
  const acc=ms.brand?.accent||C.gd;
  const bg=ms.brand?.primary||C.ob;
  const socials=Object.entries(ms.social||{}).filter(([,v])=>v).map(([k,v])=>{
    const urls={ig:`https://instagram.com/${v}`,fb:`https://facebook.com/${v}`,tw:`https://twitter.com/${v}`,tiktok:`https://tiktok.com/@${v}`,website:v};
    const icons={ig:"📸",fb:"👍",tw:"🐦",tiktok:"🎵",website:"🌐"};
    return {href:urls[k]||"#",icon:icons[k]||"🔗",label:k};
  });
  const tabs=[{id:"about",label:"About"},{id:"offers",label:"Offers"},{id:open?"enquire":"notify",label:open?"Book / Enquire":"Get Notified"}];
  return <TxWindow accent={acc} bg={bg} icon={t.e} title={t.name} badge={<><Badge t={t}/><span style={{fontSize:10,letterSpacing:1.5,textTransform:"uppercase",color:C.mu}}>{t.cat} · {t.floor}</span></>} onClose={onClose}>
    {ms.hours&&ms.hours!=="Coming Soon"&&<div style={{background:`${acc}10`,borderBottom:`1px solid ${acc}20`,padding:"6px 24px",fontSize:12,color:C.ivD,flexShrink:0}}>🕐 {ms.hours}</div>}
    <TxTabs tabs={tabs} active={tab} onChange={setTab} accent={acc}/>
    <div style={{padding:"20px 24px"}}>
      {tab==="about"&&<div>
        <p style={{fontSize:14,color:C.ivD,lineHeight:1.9,marginBottom:16}}>{ms.about||t.desc}</p>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8,marginBottom:14}}>
          {[["Floor",t.floor],["Hours",ms.hours||"—"],["Category",t.cat],["Status",t.st]].map(([k,v])=>(
            <div key={k} style={{padding:"9px 12px",background:C.obL}}><div style={{fontSize:9,letterSpacing:2,textTransform:"uppercase",color:C.mu,marginBottom:2}}>{k}</div><div style={{fontSize:13,color:C.iv}}>{v}</div></div>
          ))}
        </div>
        {socials.length>0&&<div style={{display:"flex",gap:6,flexWrap:"wrap"}}>
          {socials.map(({href,icon,label})=>(
            <a key={label} href={href} target="_blank" rel="noreferrer" style={{display:"flex",alignItems:"center",gap:5,fontSize:11,color:C.mu,textDecoration:"none",padding:"4px 9px",background:C.obL,border:`1px solid rgba(201,168,76,.1)`,transition:"all .2s"}}
              onMouseEnter={e=>{e.currentTarget.style.borderColor=acc;e.currentTarget.style.color=acc;}} onMouseLeave={e=>{e.currentTarget.style.borderColor="rgba(201,168,76,.1)";e.currentTarget.style.color=C.mu;}}>{icon} <span style={{letterSpacing:1,textTransform:"uppercase"}}>{label}</span></a>
          ))}
        </div>}
      </div>}
      {tab==="offers"&&<div>
        {user&&tier&&<div style={{padding:"8px 12px",background:C.obL,borderLeft:`2px solid ${tier.col}`,fontSize:12,color:C.mu,marginBottom:14}}>You earn <strong style={{color:C.gd}}>{tier.mult}x Vista Points</strong> here as a <span style={{color:tier.txt}}>{user.tier}</span> member.</div>}
        {!user&&<p style={{fontSize:12,color:C.mu,marginBottom:14}}>Sign in to activate your membership benefits here.</p>}
