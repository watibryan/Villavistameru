          <button onClick={onClose} style={{background:"none",border:"none",color:C.mu,fontSize:20,cursor:"pointer",flexShrink:0,lineHeight:1}}>✕</button>
        </div>
        <div style={{flex:1}}>{children}</div>
      </div>
    </div>
  </>;
}

// Tab bar used inside TxWindow
