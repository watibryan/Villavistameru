function Toast({msg,onClose}) {
  useEffect(()=>{const t=setTimeout(onClose,4000);return()=>clearTimeout(t);},[]);
  return <div style={{position:"fixed",bottom:84,right:20,zIndex:500,background:C.obL,border:`1px solid ${C.gd}`,padding:"12px 16px",display:"flex",gap:9,alignItems:"center",maxWidth:300,animation:"su .3s ease"}}><span style={{color:C.gd,flexShrink:0}}>✦</span><span style={{fontSize:12,color:C.iv,lineHeight:1.5}}>{msg}</span></div>;
}
function Overlay({onClose}) {
  return <div onClick={onClose} style={{position:"fixed",inset:0,background:"rgba(0,0,0,.9)",backdropFilter:"blur(8px)",zIndex:400}}/>;
}
function BtnG({children,onClick,full,sm,style={}}) {
  return <button onClick={onClick} style={{background:C.gd,color:C.ob,border:"none",padding:sm?"8px 16px":"11px 24px",fontFamily:"inherit",fontSize:sm?10:11,fontWeight:600,letterSpacing:2,textTransform:"uppercase",cursor:"pointer",width:full?"100%":"auto",transition:"background .2s",...style}}
    onMouseEnter={e=>e.currentTarget.style.background=C.gdL} onMouseLeave={e=>e.currentTarget.style.background=C.gd}>{children}</button>;
}
function BtnO({children,onClick,full,sm,style={}}) {
  return <button onClick={onClick} style={{background:"transparent",color:C.gd,border:`1px solid ${C.gd}`,padding:sm?"8px 16px":"11px 24px",fontFamily:"inherit",fontSize:sm?10:11,fontWeight:600,letterSpacing:2,textTransform:"uppercase",cursor:"pointer",width:full?"100%":"auto",transition:"all .2s",...style}}
    onMouseEnter={e=>{e.currentTarget.style.background=C.gd;e.currentTarget.style.color=C.ob;}} onMouseLeave={e=>{e.currentTarget.style.background="transparent";e.currentTarget.style.color=C.gd;}}>{children}</button>;
}
function Inp({label,...p}) {
