function TxWindow({accent=C.gd,bg=C.ob,icon,title,sub,badge,onClose,children,wide}) {
  return <>
    <Overlay onClose={onClose}/>
    <div style={{position:"fixed",inset:0,zIndex:401,display:"flex",alignItems:"center",justifyContent:"center",padding:16,overflowY:"auto"}}>
      <div style={{background:C.ob,border:`1px solid ${accent}40`,maxWidth:wide?740:640,width:"100%",maxHeight:"92vh",overflowY:"auto",display:"flex",flexDirection:"column",position:"relative"}}>
        {/* Branded header */}
        <div style={{background:bg,borderBottom:`2px solid ${accent}`,padding:"18px 24px",display:"flex",alignItems:"center",gap:14,position:"sticky",top:0,zIndex:10,flexShrink:0}}>
          {icon&&<div style={{width:46,height:46,background:`${accent}18`,border:`1px solid ${accent}40`,display:"flex",alignItems:"center",justifyContent:"center",fontSize:22,borderRadius:4,flexShrink:0}}>{icon}</div>}
          <div style={{flex:1,minWidth:0}}>
            <h3 style={{fontFamily:"Georgia,serif",fontSize:19,fontWeight:300,color:C.iv,marginBottom:badge?3:0,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{title}</h3>
            {badge&&<div style={{display:"flex",gap:7,alignItems:"center",flexWrap:"wrap"}}>{badge}</div>}
            {sub&&!badge&&<p style={{fontSize:11,color:C.mu,marginTop:2}}>{sub}</p>}
