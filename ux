function Badge({t}) {
  if(t.owned) return <span style={bs("#9BB5D4","rgba(155,181,212,.12)")}>Villa Vista</span>;
  if(t.anchor) return <span style={bs(C.gdL,"rgba(201,168,76,.15)")}>Anchor Tenant</span>;
  if(isOpen(t)) return <span style={bs(C.ok,"rgba(46,204,113,.12)")}>Open</span>;
  return <span style={bs(C.tc,"rgba(184,92,56,.12)")}>Coming Soon</span>;
}
