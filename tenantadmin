const STORAGE_KEY = (id) => `ms-${id}`;

const CSS = `
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  body{background:#0D0F14;color:#F5F0E8;font-family:'Inter',sans-serif;font-weight:300;min-height:100vh}
  input,textarea,select{background:#1E2330;border:1px solid rgba(201,168,76,.2);color:#F5F0E8;padding:9px 12px;font-family:inherit;font-size:13px;width:100%;outline:none;transition:border-color .2s;border-radius:2px}
  input:focus,textarea:focus,select:focus{border-color:#C9A84C}
  input::placeholder,textarea::placeholder{color:#8A8FA0}
  label{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:#8A8FA0;display:block;margin-bottom:5px}
